<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:fx="clr-namespace:BuffBar.Effects">

    <!-- ============================================================
         Palette BuffBar â€” esthÃ©tique Waybar / KDE Plasma
         Sobre, fond noir, texte blanc, encadrement gris.
         ============================================================ -->

    <SolidColorBrush x:Key="BarBackground"      Color="#000000"/>
    <SolidColorBrush x:Key="ModuleBackground"   Color="#000000"/>
    <SolidColorBrush x:Key="ModuleBorderBrush"  Color="#3A3A3A"/>
    <SolidColorBrush x:Key="HoverBackground"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="HoverBorderBrush"   Color="#555555"/>
    <SolidColorBrush x:Key="PrimaryText"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubtleText"         Color="#C8C8C8"/>

    <!-- Accent identitaire (#ddff24) disponible pour usage futur :
         workspace actif, indicateur d'enregistrement OBS, pic du visualiseur, etc. -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#FFFFFF"/>

    <!-- ============================================================
         Typographie â€” JetBrainsMono Nerd Font (repli Consolas)
         ============================================================ -->

    <FontFamily x:Key="AppFont">JetBrainsMono Nerd Font, Consolas, monospace</FontFamily>
    <!-- ============================================================
         Cadre de module individuel + glitch discret au survol
         Sprint-005: retour a des modules lisibles, sans perdre l'identite Buff.
         ============================================================ -->

    <Style x:Key="ModuleBorder" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource ModuleBackground}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="12,2"/>
        <Setter Property="Margin"          Value="4,6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="{DynamicResource HoverBackground}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.000" Value="0"/>
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.025" Value="-1"/>
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.050" Value="2"/>
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.075" Value="-1"/>
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.100" Value="1"/>
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.125" Value="0"/>
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Texte standard d'un module -->
    <Style x:Key="ModuleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <!-- Décryptage « glitch » à l'apparition de la barre (effet jh3y porté en WPF).
             Le texte passe en accent #ddff24 pendant le scramble puis reprend sa couleur. -->
        <Setter Property="fx:GlitchText.RevealOnLoad" Value="True"/>
        <Setter Property="fx:GlitchText.AccentWhileGlitching" Value="{DynamicResource AccentBrush}"/>
        <!-- Participe à l'onde de glitch déclenchée au changement de chanson. -->
        <Setter Property="fx:GlitchText.WaveMember" Value="True"/>
    </Style>

    <!-- ============================================================
         Flyouts / applets (popups ouverts au clic sur un module)
         ============================================================ -->

    <!-- Fond du panneau : suit le thème (ModuleBackground) pour rester cohérent
         avec la couleur du texte. En thème buff il reste #000000 opaque ; en thème
         Windows clair il devient clair -> le texte du thème redevient lisible.
         Opaque dans tous les cas : lisible même quand la barre est acrylique. -->
    <SolidColorBrush x:Key="FlyoutBackground" Color="#0C0C0C"/>

    <Style x:Key="FlyoutBorder" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource ModuleBackground}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="14"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
        <!-- BUFFMYBAR_SPRINT003_MICRO_HOVER -->
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlyoutHeading" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="fx:GlitchText.RevealOnLoad" Value="False"/>
        <Setter Property="fx:GlitchText.WaveMember" Value="False"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style x:Key="FlyoutText" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="fx:GlitchText.RevealOnLoad" Value="False"/>
        <Setter Property="fx:GlitchText.WaveMember" Value="False"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="FlyoutSubtle" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="fx:GlitchText.RevealOnLoad" Value="False"/>
        <Setter Property="fx:GlitchText.WaveMember" Value="False"/>
        <Setter Property="Foreground" Value="{DynamicResource SubtleText}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>

    <!-- Bouton plat (jour de calendrier) -->
    <Style x:Key="CalDayButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Width"      Value="30"/>
        <Setter Property="Height"     Value="28"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b"
                            Background="{TemplateBinding Background}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton de navigation (mois prÃ©cÃ©dent / suivant) -->
    <Style x:Key="CalNavButton" TargetType="Button" BasedOn="{StaticResource CalDayButton}">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="Width"      Value="28"/>
    </Style>

</ResourceDictionary>

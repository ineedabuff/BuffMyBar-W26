<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Palette BuffBar — esthétique Waybar / KDE Plasma
         Sobre, fond noir, texte blanc, encadrement gris.
         ============================================================ -->

    <SolidColorBrush x:Key="BarBackground"      Color="#000000"/>
    <SolidColorBrush x:Key="ModuleBackground"   Color="#000000"/>
    <SolidColorBrush x:Key="ModuleBorderBrush"  Color="#3A3A3A"/>
    <SolidColorBrush x:Key="HoverBackground"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="HoverBorderBrush"   Color="#555555"/>
    <SolidColorBrush x:Key="PrimaryText"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubtleText"         Color="#C8C8C8"/>

    <!-- Accent identitaire (#ddff24) disponible pour usage futur :
         workspace actif, indicateur d'enregistrement OBS, pic du visualiseur, etc. -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#DDFF24"/>

    <!-- ============================================================
         Typographie — JetBrainsMono Nerd Font (repli Consolas)
         ============================================================ -->

    <FontFamily x:Key="AppFont">JetBrainsMono Nerd Font, Consolas, monospace</FontFamily>

    <!-- ============================================================
         Cadre de module individuel + survol gris
         ============================================================ -->

    <Style x:Key="ModuleBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource ModuleBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource ModuleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="12,2"/>
        <Setter Property="Margin"          Value="4,6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="{StaticResource HoverBackground}"/>
                <Setter Property="BorderBrush" Value="{StaticResource HoverBorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Texte standard d'un module -->
    <Style x:Key="ModuleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ============================================================
         Flyouts / applets (popups ouverts au clic sur un module)
         ============================================================ -->

    <!-- Fond du panneau : volontairement opaque et sombre, pour rester lisible
         même quand la barre est en mode acrylique translucide. -->
    <SolidColorBrush x:Key="FlyoutBackground" Color="#0C0C0C"/>

    <Style x:Key="FlyoutBorder" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource FlyoutBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlyoutHeading" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style x:Key="FlyoutText" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="FlyoutSubtle" TargetType="TextBlock" BasedOn="{StaticResource ModuleText}">
        <Setter Property="Foreground" Value="{StaticResource SubtleText}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>

    <!-- Bouton plat (jour de calendrier) -->
    <Style x:Key="CalDayButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Width"      Value="30"/>
        <Setter Property="Height"     Value="28"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b"
                            Background="{TemplateBinding Background}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource HoverBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton de navigation (mois précédent / suivant) -->
    <Style x:Key="CalNavButton" TargetType="Button" BasedOn="{StaticResource CalDayButton}">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="Width"      Value="28"/>
    </Style>

</ResourceDictionary>

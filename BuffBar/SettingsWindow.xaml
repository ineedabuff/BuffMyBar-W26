<Window x:Class="BuffBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BuffMyBar W26 — Paramètres"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0C0C0C"
        Foreground="#FFFFFF"
        FontFamily="{StaticResource AppFont}"
        FontSize="13"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDFF24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,3,16,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="CaretBrush" Value="#DDFF24"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="700">
        <StackPanel Margin="18">

            <TextBlock Text="Thème" Style="{StaticResource Header}" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ThemeBuff"    GroupName="theme" Content="Buff"/>
                <RadioButton x:Name="ThemeWindows" GroupName="theme" Content="Windows"/>
                <RadioButton x:Name="ThemeCyber"   GroupName="theme" Content="Cyber"/>
            </StackPanel>

            <TextBlock Text="Hauteur (DIP)" Style="{StaticResource Header}"/>
            <TextBox x:Name="HeightBox" Style="{StaticResource Field}" Width="80"/>

            <TextBlock Text="Ville (météo)" Style="{StaticResource Header}"/>
            <TextBox x:Name="CityBox" Style="{StaticResource Field}" Width="220"/>

            <TextBlock Text="Options" Style="{StaticResource Header}"/>
            <CheckBox x:Name="GamingBox"   Content="Mode jeu — ping dans le widget réseau"/>
            <CheckBox x:Name="ExtAccentBox" Content="Accent #ddff24 sur le moniteur externe"/>
            <CheckBox x:Name="AcrylicBox"  Content="Fond acrylique translucide"/>

            <TextBlock Text="Widgets" Style="{StaticResource Header}"/>
            <CheckBox x:Name="WWeather"    Content="Météo"/>
            <CheckBox x:Name="WUptime"     Content="Uptime"/>
            <CheckBox x:Name="WNetwork"    Content="Réseau"/>
            <CheckBox x:Name="WMedia"      Content="Média"/>
            <CheckBox x:Name="WObs"        Content="OBS"/>
            <CheckBox x:Name="WVisualizer" Content="Visualiseur"/>
            <CheckBox x:Name="WVolume"     Content="Volume"/>
            <CheckBox x:Name="WBluetooth"  Content="Bluetooth"/>
            <CheckBox x:Name="WBattery"    Content="Batterie"/>

            <TextBlock Text="OBS (obs-websocket)" Style="{StaticResource Header}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Hôte" Margin="0,4,10,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="ObsHostBox" Margin="0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" Margin="0,4,10,4"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ObsPortBox" Margin="0,4" Width="100" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mot de passe" Margin="0,4,10,4"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ObsPassBox" Margin="0,4"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Annuler" Click="OnCancel"
                        Padding="14,6" Margin="0,0,8,0" Background="#000000" Foreground="#FFFFFF"
                        BorderBrush="#3A3A3A"/>
                <Button x:Name="SaveButton" Content="Enregistrer" Click="OnSave"
                        Padding="16,6" Background="#DDFF24" Foreground="#000000" BorderBrush="#DDFF24"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>

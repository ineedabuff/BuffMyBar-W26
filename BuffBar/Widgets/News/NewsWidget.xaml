<UserControl x:Class="BuffBar.Widgets.News.NewsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:BuffBar.Widgets.Common"
             VerticalAlignment="Stretch">

    <!-- Bandeau d'actualités défilant (faits divers, région de Montréal) -->
    <Border x:Name="Root"
            Style="{StaticResource ModuleBorder}"
            ToolTip="Faits divers — région de Montréal">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="Icon"
                       Style="{StaticResource ModuleText}"
                       FontSize="12"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"/>
            <common:MarqueeText x:Name="Label"
                                MaxWidth="360"
                                TextSize="12"
                                VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>

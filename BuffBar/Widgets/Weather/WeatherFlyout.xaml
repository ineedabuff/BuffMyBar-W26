<UserControl x:Class="BuffBar.Widgets.Weather.WeatherFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BuffBar.Widgets.Weather">

    <!-- Surcharge locale : tout le texte du flyout en blanc (le reste de l'app garde le thème). -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleText"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFFF"/>
    </UserControl.Resources>

    <Border Style="{StaticResource FlyoutBorder}" MinWidth="260">
        <StackPanel>

            <!-- Lieu -->
            <TextBlock x:Name="Location"
                       Style="{StaticResource FlyoutHeading}"
                       Margin="0,0,0,8"/>

            <!-- Conditions actuelles : grande icône + température -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <local:AnimatedWeatherIcon x:Name="BigIcon"
                                           Width="46" Height="46"
                                           Margin="0,0,14,0"
                                           VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="BigTemp"
                               Style="{StaticResource ModuleText}"
                               FontSize="26"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="Desc"
                               Style="{StaticResource FlyoutSubtle}"/>
                </StackPanel>
            </StackPanel>

            <!-- Détails -->
            <TextBlock x:Name="Details"
                       Style="{StaticResource FlyoutSubtle}"
                       Margin="0,10,0,0"/>

            <Border Height="1" Background="{StaticResource ModuleBorderBrush}" Margin="0,12,0,10"/>

            <!-- Prévisions (3 jours) -->
            <UniformGrid x:Name="ForecastGrid" Rows="1"/>
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="BuffBar.Widgets.Battery.BatteryWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BuffBar.Widgets.Battery"
             VerticalAlignment="Stretch">

    <Border x:Name="Root" Style="{StaticResource ModuleBorder}">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <local:BatteryIcon x:Name="Icon"
                               Width="26" Height="14"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
            <TextBlock x:Name="Percent"
                       Style="{StaticResource ModuleText}"
                       FontSize="13"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>

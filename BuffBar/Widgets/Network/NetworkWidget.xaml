<UserControl x:Class="BuffBar.Widgets.Network.NetworkWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch">

    <Border x:Name="Root" Style="{StaticResource ModuleBorder}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Segment ping (mode jeu uniquement) -->
            <TextBlock x:Name="PingIcon"
                       Style="{StaticResource ModuleText}"
                       FontSize="15"
                       Margin="0,0,6,0"
                       Visibility="Collapsed"/>
            <TextBlock x:Name="Ping"
                       Style="{StaticResource ModuleText}"
                       FontSize="12"
                       Width="64"
                       TextAlignment="Left"
                       Margin="0,0,10,0"
                       Visibility="Collapsed"/>

            <TextBlock x:Name="Icon"
                       Style="{StaticResource ModuleText}"
                       FontSize="15"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="Ip"
                       Style="{StaticResource ModuleText}"
                       FontSize="12"
                       Width="118"
                       TextAlignment="Left"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>
    </Border>
</UserControl>

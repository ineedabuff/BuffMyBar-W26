<UserControl x:Class="BuffBar.Widgets.Volume.VolumeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BuffBar.Widgets.Volume"
             VerticalAlignment="Stretch">

    <!-- Molette = +/- volume, clic gauche = muet -->
    <Border x:Name="Root"
            Style="{StaticResource ModuleBorder}"
            MouseWheel="OnMouseWheel"
            MouseLeftButtonUp="OnLeftClick"
            ToolTip="Molette : volume â€” Clic : muet">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <local:VolumeIcon x:Name="Icon"
                              Width="16" Height="16"
                              Margin="0,0,5,0"
                              VerticalAlignment="Center"/>

            <TextBlock x:Name="PercentLabel"
                       Style="{StaticResource ModuleText}"
                       FontSize="13"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
<UserControl x:Class="BuffBar.Widgets.Visualizer.VisualizerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viz="clr-namespace:BuffBar.Widgets.Visualizer"
             VerticalAlignment="Stretch">

    <Border Style="{StaticResource ModuleBorder}">
        <viz:SpectrumView x:Name="Spectrum"
                          Width="240"
                          VerticalAlignment="Stretch"
                          ClipToBounds="True"/>
    </Border>
</UserControl>

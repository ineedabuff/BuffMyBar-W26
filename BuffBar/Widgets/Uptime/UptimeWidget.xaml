<UserControl x:Class="BuffBar.Widgets.Uptime.UptimeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch">

    <Border x:Name="Root" Style="{StaticResource ModuleBorder}" ToolTip="Temps de fonctionnement">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="Icon"
                       Style="{StaticResource ModuleText}"
                       FontSize="15"
                       Margin="0,0,8,0"
                       Text="&#xF1DA;"/>
            <TextBlock x:Name="Label"
                       Style="{StaticResource ModuleText}"
                       FontSize="12"/>
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="BuffBar.Widgets.Clock.CalendarFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surcharge locale : tout le texte du flyout en blanc (le reste de l'app garde le thème). -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleText"  Color="#FFFFFF"/>
    </UserControl.Resources>

    <Border Style="{StaticResource FlyoutBorder}" Width="300">
        <StackPanel>

            <!-- En-tête : ‹  Mois AAAA  › -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton" Grid.Column="0"
                        Style="{StaticResource CalNavButton}" Content="&#xF053;"
                        Foreground="#FFFFFF"
                        ToolTip="Mois précédent"/>

                <TextBlock x:Name="MonthLabel" Grid.Column="1"
                           Style="{StaticResource FlyoutHeading}"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"/>

                <Button x:Name="NextButton" Grid.Column="2"
                        Style="{StaticResource CalNavButton}" Content="&#xF054;"
                        Foreground="#FFFFFF"
                        ToolTip="Mois suivant"/>
            </Grid>

            <!-- En-tête des jours de la semaine (lundi -> dimanche) -->
            <UniformGrid x:Name="WeekHeader" Columns="7" Margin="0,0,0,2"/>

            <!-- Grille des jours -->
            <UniformGrid x:Name="DayGrid" Columns="7"/>

            <Border Height="1" Background="{StaticResource ModuleBorderBrush}" Margin="0,10,0,8"/>

            <!-- Événements du jour sélectionné -->
            <TextBlock x:Name="SelectedDateLabel" Style="{StaticResource FlyoutHeading}" Foreground="#FFFFFF" FontSize="12"/>
            <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                <StackPanel x:Name="EventList"/>
            </ScrollViewer>
            <TextBlock x:Name="EventHint" Style="{StaticResource FlyoutSubtle}" Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</UserControl>

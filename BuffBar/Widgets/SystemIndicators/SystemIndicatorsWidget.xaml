<UserControl x:Class="BuffBar.Widgets.SystemIndicators.SystemIndicatorsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BuffBar.Widgets.SystemIndicators"
             VerticalAlignment="Stretch">

    <Grid>
        <Border x:Name="Root"
                Style="{StaticResource ModuleBorder}"
                ToolTip="Système (détails au survol)">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock x:Name="CpuLabel"
                           Style="{StaticResource ModuleText}"
                           FontSize="12"
                           Margin="0,0,10,0"/>

                <TextBlock x:Name="RamLabel"
                           Style="{StaticResource ModuleText}"
                           FontSize="12"
                           Margin="0,0,10,0"/>

                <TextBlock x:Name="GpuLabel"
                           Style="{StaticResource ModuleText}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Applet système détaillée (s'ouvre au survol) -->
        <Popup x:Name="Flyout"
               PlacementTarget="{Binding ElementName=Root}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               VerticalOffset="4">
            <local:SystemFlyout x:Name="Monitor"/>
        </Popup>
    </Grid>
</UserControl>

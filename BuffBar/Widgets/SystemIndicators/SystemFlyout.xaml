<UserControl x:Class="BuffBar.Widgets.SystemIndicators.SystemFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource FlyoutBorder}" MinWidth="220">
        <StackPanel>

            <TextBlock Text="Système" Style="{StaticResource FlyoutHeading}" Margin="0,0,0,10"/>

            <!-- CPU -->
            <StackPanel x:Name="CpuRow" Margin="0,0,0,9">
                <Grid>
                    <TextBlock Text="CPU" Style="{StaticResource FlyoutSubtle}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="CpuValue" Style="{StaticResource FlyoutText}" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Height="5" Margin="0,3,0,0">
                    <Border Background="{DynamicResource HoverBackground}" CornerRadius="2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CpuFill" Width="0*"/>
                            <ColumnDefinition x:Name="CpuTrack" Width="100*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <!-- RAM -->
            <StackPanel x:Name="RamRow" Margin="0,0,0,9">
                <Grid>
                    <TextBlock Text="RAM" Style="{StaticResource FlyoutSubtle}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="RamValue" Style="{StaticResource FlyoutText}" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Height="5" Margin="0,3,0,0">
                    <Border Background="{DynamicResource HoverBackground}" CornerRadius="2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="RamFill" Width="0*"/>
                            <ColumnDefinition x:Name="RamTrack" Width="100*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <!-- GPU -->
            <StackPanel x:Name="GpuRow" Margin="0,0,0,9">
                <Grid>
                    <TextBlock Text="GPU" Style="{StaticResource FlyoutSubtle}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="GpuValue" Style="{StaticResource FlyoutText}" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Height="5" Margin="0,3,0,0">
                    <Border Background="{DynamicResource HoverBackground}" CornerRadius="2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="GpuFill" Width="0*"/>
                            <ColumnDefinition x:Name="GpuTrack" Width="100*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <!-- Température CPU -->
            <StackPanel x:Name="TempRow">
                <Grid>
                    <TextBlock Text="Température CPU" Style="{StaticResource FlyoutSubtle}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TempValue" Style="{StaticResource FlyoutText}" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Height="5" Margin="0,3,0,0">
                    <Border Background="{DynamicResource HoverBackground}" CornerRadius="2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="TempFill" Width="0*"/>
                            <ColumnDefinition x:Name="TempTrack" Width="100*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <TextBlock x:Name="EmptyNote"
                       Text="Aucune donnée disponible"
                       Style="{StaticResource FlyoutSubtle}"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>

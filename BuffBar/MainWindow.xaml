<Window x:Class="BuffBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BuffBar"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="{StaticResource BarBackground}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{StaticResource AppFont}"
        Foreground="{StaticResource PrimaryText}">

    <!-- Menu contextuel : seul moyen de quitter (la barre n'a pas d'entrée dans la barre des tâches) -->
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Recharger la position" Click="OnReload"/>
            <Separator/>
            <MenuItem Header="Quitter BuffBar" Click="OnQuit"/>
        </ContextMenu>
    </Window.ContextMenu>

    <!--
        Trois régions superposées dans une seule cellule pour que le CENTRE
        soit aligné sur le centre réel de l'écran, indépendamment de la largeur
        des modules gauche/droite (comportement type Waybar).
    -->
    <Grid>
        <StackPanel x:Name="LeftRegion"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"/>

        <ContentControl x:Name="CenterRegion"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"/>

        <StackPanel x:Name="RightRegion"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"/>
    </Grid>
</Window>
